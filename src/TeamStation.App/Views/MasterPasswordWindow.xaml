<Window x:Class="TeamStation.App.Views.MasterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master password"
        Width="520"
        Height="340"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE72E;"
                           Foreground="{StaticResource BlueBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="PORTABLE MODE" Style="{StaticResource CaptionText}" Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="TitleText" Style="{StaticResource HeadlineText}" />
            <TextBlock x:Name="SubtitleText"
                       Margin="0,8,0,0"
                       Style="{StaticResource SectionSubtitleText}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,22,0,0">
            <TextBlock Text="Master password" Style="{StaticResource FieldLabelText}" />
            <PasswordBox x:Name="PasswordBox"
                         AutomationProperties.Name="Master password"
                         AutomationProperties.HelpText="Use at least 10 characters."
                         PasswordChanged="PasswordBox_PasswordChanged" />
            <TextBlock x:Name="PasswordHelpText"
                       Margin="0,6,0,0"
                       Text="Use at least 10 characters."
                       Style="{StaticResource BodyMutedText}" />

            <StackPanel x:Name="ConfirmPanel" Margin="0,16,0,0">
                <TextBlock Text="Confirm master password" Style="{StaticResource FieldLabelText}" />
                <PasswordBox x:Name="ConfirmBox"
                             AutomationProperties.Name="Confirm master password"
                             AutomationProperties.HelpText="Re-enter the same master password."
                             PasswordChanged="PasswordBox_PasswordChanged" />
            </StackPanel>

            <Border x:Name="ValidationBorder"
                    Margin="0,16,0,0"
                    Style="{StaticResource ValidationBanner}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                               FontSize="13"
                               Text="&#xE814;"
                               Foreground="{StaticResource RedBrush}"
                               VerticalAlignment="Top"
                               Margin="0,1,10,0" />
                    <TextBlock x:Name="ValidationText" Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button DockPanel.Dock="Right"
                    x:Name="ContinueButton"
                    Content="Continue"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    ToolTip="Enter a master password with at least 10 characters."
                    ToolTipService.ShowOnDisabled="True"
                    Click="Continue_Click" />
        </DockPanel>
    </Grid>
</Window>
