<Window x:Class="TeamStation.App.Views.MasterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master password"
        Width="520"
        Height="340"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText"
                       Margin="0,10,0,0"
                       Style="{StaticResource SectionSubtitleText}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,22,0,0">
            <TextBlock Text="Master password" Style="{StaticResource FieldLabelText}" />
            <PasswordBox x:Name="PasswordBox" />

            <StackPanel x:Name="ConfirmPanel" Margin="0,16,0,0">
                <TextBlock Text="Confirm master password" Style="{StaticResource FieldLabelText}" />
                <PasswordBox x:Name="ConfirmBox" />
            </StackPanel>

            <Border x:Name="ValidationBorder"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{StaticResource RedSoftBrush}"
                    BorderBrush="#44E86D8F"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="Collapsed">
                <TextBlock x:Name="ValidationText" Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button DockPanel.Dock="Right"
                    Content="Continue"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    Click="Continue_Click" />
        </DockPanel>
    </Grid>
</Window>
