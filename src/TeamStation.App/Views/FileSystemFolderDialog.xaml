<Window x:Class="TeamStation.App.Views.FileSystemFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TeamStation.App.Views"
        Title="Select folder"
        Width="640"
        Height="720"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FolderDialogCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE8B7;"
                           Foreground="{StaticResource BlueBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="FOLDER"
                           Style="{StaticResource CaptionText}"
                           Foreground="{StaticResource BlueBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="DialogTitleText" Style="{StaticResource HeadlineText}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Choose a local folder from available drives, or paste a folder path directly."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="Folder path" Style="{StaticResource FieldLabelText}" />
            <TextBox x:Name="PathBox"
                     TextChanged="PathBox_TextChanged" />
        </StackPanel>

        <Border Grid.Row="2" Margin="0,14,0,0" Style="{StaticResource FolderDialogCard}">
            <TreeView x:Name="FolderTree"
                      ItemsSource="{Binding RootFolders}"
                      SelectedItemChanged="FolderTree_SelectedItemChanged"
                      MouseDoubleClick="FolderTree_MouseDoubleClick">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type local:FileSystemFolderItem}" ItemsSource="{Binding Children}">
                        <Border x:Name="FolderRow"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                           FontSize="13"
                                           Text="{Binding Icon}"
                                           Foreground="{StaticResource BlueBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Path}"
                                               Foreground="{StaticResource Subtext0Brush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding ShowPath, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                <Setter TargetName="FolderRow" Property="Opacity" Value="0.65" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsMouseOver}" Value="True">
                                <Setter TargetName="FolderRow" Property="Background" Value="{DynamicResource Surface1Brush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsKeyboardFocusWithin}" Value="True">
                                <Setter TargetName="FolderRow" Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="FolderRow" Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                                <Setter TargetName="FolderRow" Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <Border x:Name="ValidationBorder"
                Grid.Row="3"
                Margin="0,14,0,0"
                Style="{StaticResource ValidationBanner}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="14"
                           Text="&#xE814;"
                           Foreground="{StaticResource RedBrush}"
                           VerticalAlignment="Top"
                           Margin="0,1,10,0" />
                <TextBlock x:Name="ValidationText"
                           Foreground="{StaticResource RedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,20,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    x:Name="OkButton"
                    Content="Use folder"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="Ok_Click" />
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </DockPanel>
    </Grid>
</Window>
