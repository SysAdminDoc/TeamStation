<Window x:Class="TeamStation.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="700"
        MinWidth="660"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Margin="0,10,0,0"
                       Text="Configure launch behavior, optional TeamViewer cloud access, and power-user helpers."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="TeamViewer executable" Style="{StaticResource FieldLabelText}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TeamViewerPathBox" />
                    <Button Grid.Column="2" Content="Browse" Click="Browse_Click" />
                </Grid>
                <TextBlock Margin="0,6,0,18" Text="Leave blank to use registry and standard install path discovery." Style="{StaticResource BodyMutedText}" />

                <TextBlock Text="TeamViewer Web API token" Style="{StaticResource FieldLabelText}" />
                <PasswordBox x:Name="ApiTokenBox" />
                <TextBlock Margin="0,6,0,18" Text="Read-only script token used for group/device sync and online status checks." Style="{StaticResource BodyMutedText}" />

                <CheckBox x:Name="WakeBox" Content="Send Wake-on-LAN before launch when a connection has a MAC address" Margin="0,0,0,10" />

                <CheckBox x:Name="ClipboardPasswordBox"
                          Content="Launch without password on the command line (stage it on the clipboard instead — clears in 30s)"
                          Margin="0,0,0,4" />
                <TextBlock Margin="0,0,0,18"
                           Text="Reduces the command-line password disclosure window on shared or hostile hosts. You'll paste the password into the TeamViewer prompt."
                           Style="{StaticResource BodyMutedText}" />

                <TextBlock Text="Cloud sync folder" Style="{StaticResource FieldLabelText}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CloudFolderBox" />
                    <Button Grid.Column="2" Content="Browse" Click="BrowseCloud_Click" />
                </Grid>
                <TextBlock Margin="0,6,0,18" Text="Optional backup mirror folder. TeamStation writes an encrypted DB copy after changes." Style="{StaticResource BodyMutedText}" />

                <TextBlock Text="Saved searches" Style="{StaticResource FieldLabelText}" />
                <TextBox x:Name="SavedSearchesBox"
                         AcceptsReturn="True"
                         Height="90"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto" />
                <TextBlock Margin="0,6,0,18" Text="One search per line." Style="{StaticResource BodyMutedText}" />

                <TextBlock Text="External tools" Style="{StaticResource FieldLabelText}" />
                <TextBox x:Name="ExternalToolsBox"
                         AcceptsReturn="True"
                         Height="130"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto" />
                <TextBlock Margin="0,6,0,0" Text="One per line: Name|Command|Arguments. Variables: %ID%, %NAME%, %PASSWORD%, %TAG:key%, ${ENV_VAR}." Style="{StaticResource BodyMutedText}" />
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,20,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0"
                    Click="Cancel_Click"
                    IsCancel="True" />
            <Button DockPanel.Dock="Right"
                    Content="Save settings"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"
                    IsDefault="True" />
        </DockPanel>
    </Grid>
</Window>
