<Window x:Class="TeamStation.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="700"
        MinWidth="660"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22,20" />
        </Style>
        <Style x:Key="TrustSignal" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE713;"
                           Foreground="{StaticResource Subtext1Brush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="PREFERENCES" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource DisplayText}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Configure launch behavior, optional TeamViewer cloud access, and power-user helpers."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Trust posture  -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Security posture" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="TeamStation keeps launches fast while making credential and sync behavior explicit."
                                   Style="{StaticResource SectionSubtitleText}" />
                        <WrapPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource TrustSignal}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                               Text="&#xE72E;"
                                               Foreground="{StaticResource GreenBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="Encrypted local vault" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text="Passwords and tokens stay protected at rest." Style="{StaticResource BodyMutedText}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource TrustSignal}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                               Text="&#xE895;"
                                               Foreground="{StaticResource BlueBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="Opt-in cloud sync" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text="No Web API token means no cloud requests." Style="{StaticResource BodyMutedText}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!--  Appearance  -->
                <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Appearance" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Pick the palette that reads best in your work environment."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBlock Margin="0,18,0,0" Text="Theme" Style="{StaticResource FieldLabelText}" />
                        <ComboBox x:Name="ThemeBox"
                                  AutomationProperties.Name="Theme"
                                  AutomationProperties.HelpText="Choose the TeamStation color theme."
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id" />
                        <TextBlock Margin="0,6,0,0" Text="System follows Windows app mode; Dark, Graphite, Light, and High contrast are available for fixed environments." Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

                <!--  TeamViewer  -->
                <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="TeamViewer" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Where to find the TeamViewer client and how TeamStation authenticates against the Web API."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBlock Margin="0,18,0,0" Text="TeamViewer executable" Style="{StaticResource FieldLabelText}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TeamViewerPathBox"
                                     AutomationProperties.Name="TeamViewer executable"
                                     AutomationProperties.HelpText="Optional full path to TeamViewer.exe. Leave blank to use automatic discovery." />
                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Content="Browse"
                                    AutomationProperties.Name="Browse for TeamViewer executable"
                                    Click="Browse_Click" />
                        </Grid>
                        <TextBlock Margin="0,6,0,0" Text="Leave blank to use registry and standard install-path discovery." Style="{StaticResource BodyMutedText}" />

                        <TextBlock Margin="0,18,0,0" Text="Web API token" Style="{StaticResource FieldLabelText}" />
                        <PasswordBox x:Name="ApiTokenBox"
                                     AutomationProperties.Name="TeamViewer Web API token"
                                     AutomationProperties.HelpText="Optional read-only script token for TeamViewer cloud sync." />
                        <TextBlock Margin="0,6,0,0" Text="Read-only script token used for group / device sync and online-state checks." Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

                <!--  Launch safety  -->
                <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Launch safety" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Sensible defaults for hostile or multi-user environments."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <CheckBox x:Name="WakeBox"
                                  AutomationProperties.Name="Send Wake-on-LAN before launch"
                                  Content="Send Wake-on-LAN before launch when a connection has a MAC address"
                                  Margin="0,18,0,12" />

                        <CheckBox x:Name="ProtocolLaunchBox"
                                  AutomationProperties.Name="Prefer TeamViewer protocol links"
                                  Content="Prefer TeamViewer protocol links before launching TeamViewer.exe"
                                  Margin="0,0,0,4" />
                        <TextBlock Margin="0,0,0,12"
                                   Text="Uses registered TeamViewer protocol handlers for remote control, file transfer, and VPN when proxy, quality, or access-control overrides do not require command-line flags."
                                   Style="{StaticResource BodyMutedText}" />

                        <CheckBox x:Name="ClipboardPasswordBox"
                                  AutomationProperties.Name="Stage password on clipboard"
                                  Content="Stage password on the clipboard instead of the command line (auto-clears in 30 s)"
                                  Margin="0,0,0,4" />
                        <TextBlock Margin="0,0,0,0"
                                   Text="Reduces the command-line password disclosure window on shared or hostile hosts. You'll paste the password into the TeamViewer prompt."
                                   Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

                <!--  Backup &amp; search  -->
                <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Backup &amp; search" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Optional encrypted mirror + the named searches shown above the connection tree."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBlock Margin="0,18,0,0" Text="Cloud sync folder" Style="{StaticResource FieldLabelText}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CloudFolderBox"
                                     AutomationProperties.Name="Cloud sync folder"
                                     AutomationProperties.HelpText="Optional existing folder where TeamStation writes an encrypted backup mirror." />
                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Content="Browse"
                                    AutomationProperties.Name="Browse for cloud sync folder"
                                    Click="BrowseCloud_Click" />
                        </Grid>
                        <TextBlock Margin="0,6,0,0" Text="Optional backup mirror folder. TeamStation writes an encrypted DB copy after changes." Style="{StaticResource BodyMutedText}" />

                        <TextBlock Margin="0,18,0,0" Text="History retention" Style="{StaticResource FieldLabelText}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RetentionDaysBox"
                                     AutomationProperties.Name="History retention days"
                                     AutomationProperties.HelpText="Number of days to keep session and audit history. Use 0 to keep history indefinitely." />
                            <TextBlock Grid.Column="2"
                                       Text="days"
                                       Style="{StaticResource BodyMutedText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Margin="0,6,0,0"
                                   Text="Prunes session and audit history on startup. Use 0 to keep history indefinitely."
                                   Style="{StaticResource BodyMutedText}" />

                        <CheckBox x:Name="OptimizeDatabaseBox"
                                  AutomationProperties.Name="Optimize SQLite on connection close"
                                  Content="Optimize SQLite planner statistics when database connections close"
                                  Margin="0,18,0,4" />
                        <TextBlock Margin="0,0,0,0"
                                   Text="Keeps larger vaults responsive with SQLite's lightweight PRAGMA optimize maintenance. Disable only while diagnosing database issues."
                                   Style="{StaticResource BodyMutedText}" />

                        <TextBlock Margin="0,18,0,0" Text="Saved searches" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="SavedSearchesBox"
                                 AutomationProperties.Name="Saved searches"
                                 AutomationProperties.HelpText="One named search per line."
                                 AcceptsReturn="True"
                                 Height="90"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto" />
                        <TextBlock Margin="0,6,0,0" Text="One search per line." Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

                <!--  External tools  -->
                <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="External tools" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Shortcuts shown on each connection. Use variables to pass entry data to the external command."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBox x:Name="ExternalToolsBox"
                                 Margin="0,18,0,0"
                                 AutomationProperties.Name="External tool definitions"
                                 AutomationProperties.HelpText="One tool per line using Name, command, and optional arguments separated by vertical bars."
                                 AcceptsReturn="True"
                                 Height="130"
                                 FontFamily="{StaticResource MonoFont}"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto" />
                        <TextBlock Margin="0,6,0,0" Text="One per line: Name|Command|Arguments. Variables: %ID%, %NAME%, %PASSWORD%, %TAG:key%, ${ENV_VAR}." Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <Border x:Name="ValidationBorder"
                    Margin="0,0,0,12"
                    Style="{StaticResource ValidationBanner}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                               FontSize="13"
                               Text="&#xE814;"
                               Foreground="{StaticResource RedBrush}"
                               VerticalAlignment="Top"
                               Margin="0,1,10,0" />
                    <TextBlock x:Name="ValidationText" Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Margin="8,0,0,0"
                        Click="Cancel_Click"
                        IsCancel="True" />
                <Button DockPanel.Dock="Right"
                        Content="Save settings"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click"
                        IsDefault="True" />
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
