<Window x:Class="TeamStation.App.Views.FolderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TeamStation.Core.Models;assembly=TeamStation.Core"
        Title="Edit folder"
        Width="520" Height="580"
        MinWidth="480" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="{StaticResource Subtext1Brush}" />
            <Setter Property="Margin" Value="0,12,0,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Folder name" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="NameBox" />

                <TextBlock Text="Accent color (hex, optional)" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="AccentBox" />
                <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="11" Margin="0,4,0,0"
                           Text="e.g. #89B4FA — used as the folder dot in the tree." />

                <TextBlock Text="Default password for entries in this folder"
                           Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="DefaultPasswordBox" />
                <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="11" Margin="0,4,0,0"
                           Text="Used as the starting value when creating a new entry inside this folder. Entries keep their own password once saved." />

                <TextBlock Text="Default connection mode" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="ModeBox">
                    <ComboBoxItem Tag="{x:Null}" Content="(none — entry decides)" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.RemoteControl}" Content="Remote Control" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.FileTransfer}" Content="File Transfer" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Vpn}" Content="VPN" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Chat}" Content="Chat (URI)" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.VideoCall}" Content="Video call (URI)" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Presentation}" Content="Presentation (URI)" />
                </ComboBox>

                <TextBlock Text="Default quality" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="QualityBox">
                    <ComboBoxItem Tag="{x:Null}" Content="(none — entry decides)" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.AutoSelect}" Content="Auto" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.OptimizeQuality}" Content="Optimize quality" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.OptimizeSpeed}" Content="Optimize speed" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.CustomSettings}" Content="Custom" />
                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.Undefined}" Content="Undefined" />
                </ComboBox>

                <TextBlock Text="Default access control" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="AcBox">
                    <ComboBoxItem Tag="{x:Null}" Content="(none — entry decides)" />
                    <ComboBoxItem Tag="{x:Static models:AccessControl.Undefined}" Content="Undefined" />
                    <ComboBoxItem Tag="{x:Static models:AccessControl.FullAccess}" Content="Full access" />
                    <ComboBoxItem Tag="{x:Static models:AccessControl.ConfirmAll}" Content="Confirm all" />
                    <ComboBoxItem Tag="{x:Static models:AccessControl.ViewAndShow}" Content="View and show" />
                    <ComboBoxItem Tag="{x:Static models:AccessControl.CustomSettings}" Content="Custom" />
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click" />
            <Button Content="Save" IsDefault="True" Click="Save_Click"
                    Background="{StaticResource BlueBrush}" Foreground="{StaticResource Crust}" FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</Window>
