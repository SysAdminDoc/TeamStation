<Window x:Class="TeamStation.App.Views.FolderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TeamStation.Core.Models;assembly=TeamStation.Core"
        Title="Folder"
        Width="700"
        Height="760"
        MinWidth="620"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="EditorCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="22,20" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE8B7;"
                           Foreground="{StaticResource MauveBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="FOLDER" Style="{StaticResource CaptionText}" Foreground="{StaticResource MauveBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="DialogTitleText" Style="{StaticResource DisplayText}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Tune how this folder looks and what descendant connections inherit when they leave settings on folder defaults."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <Border x:Name="ValidationBorder"
                Grid.Row="1"
                Margin="0,16,0,0"
                Padding="14,12"
                Background="{StaticResource RedSoftBrush}"
                BorderBrush="#44E86D8F"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="14"
                           Text="&#xE814;"
                           Foreground="{StaticResource RedBrush}"
                           VerticalAlignment="Top"
                           Margin="0,1,10,0" />
                <TextBlock x:Name="ValidationText" Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource EditorCard}">
                    <StackPanel>
                        <TextBlock Text="Basics" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Give the folder a clear name and choose an accent that helps the tree scan quickly."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBlock Margin="0,18,0,0" Text="Folder name" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="NameBox" />

                        <TextBlock Margin="0,18,0,0" Text="Accent color" Style="{StaticResource FieldLabelText}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AccentBox" Grid.Column="0" TextChanged="AccentBox_TextChanged" />

                            <Border x:Name="AccentPreview"
                                    Grid.Column="2"
                                    Width="42"
                                    Height="42"
                                    CornerRadius="12"
                                    Background="{StaticResource MauveBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1" />
                        </Grid>

                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Blue" Tag="#7CB8FF" Margin="0,0,8,8" Click="AccentPreset_Click" />
                            <Button Content="Mint" Tag="#9AE6B4" Margin="0,0,8,8" Click="AccentPreset_Click" />
                            <Button Content="Rose" Tag="#FFA2B6" Margin="0,0,8,8" Click="AccentPreset_Click" />
                            <Button Content="Gold" Tag="#F4D27A" Margin="0,0,8,8" Click="AccentPreset_Click" />
                            <Button Content="Lavender" Tag="#D4B0FF" Margin="0,0,8,8" Click="AccentPreset_Click" />
                            <Button Content="Clear" Style="{StaticResource GhostButton}" Margin="0,0,0,8" Click="ClearAccent_Click" />
                        </WrapPanel>

                        <TextBlock Margin="0,6,0,0"
                                   Text="Use a six-digit hex code such as #7CB8FF, or choose a preset above."
                                   Style="{StaticResource BodyMutedText}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EditorCard}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Inherited defaults" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Connections in this folder can inherit launch behavior from here until they choose their own override."
                                   Style="{StaticResource SectionSubtitleText}" />

                        <TextBlock Margin="0,18,0,0" Text="Default password" Style="{StaticResource FieldLabelText}" />
                        <PasswordBox x:Name="DefaultPasswordBox" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Useful when a whole site shares unattended credentials. Individual connections can still override it."
                                   Style="{StaticResource BodyMutedText}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Default mode" Style="{StaticResource FieldLabelText}" />
                                <ComboBox x:Name="ModeBox">
                                    <ComboBoxItem Tag="{x:Null}" Content="Entry decides" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.RemoteControl}" Content="Remote Control" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.FileTransfer}" Content="File Transfer" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Vpn}" Content="VPN" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Chat}" Content="Chat (URI handler)" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.VideoCall}" Content="Video call (URI handler)" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionMode.Presentation}" Content="Presentation (URI handler)" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Default quality" Style="{StaticResource FieldLabelText}" />
                                <ComboBox x:Name="QualityBox">
                                    <ComboBoxItem Tag="{x:Null}" Content="Entry decides" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.AutoSelect}" Content="Auto" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.OptimizeQuality}" Content="Optimize quality" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.OptimizeSpeed}" Content="Optimize speed" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.CustomSettings}" Content="Custom" />
                                    <ComboBoxItem Tag="{x:Static models:ConnectionQuality.Undefined}" Content="Undefined" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,18,0,0" Text="Default access control" Style="{StaticResource FieldLabelText}" />
                        <ComboBox x:Name="AcBox">
                            <ComboBoxItem Tag="{x:Null}" Content="Entry decides" />
                            <ComboBoxItem Tag="{x:Static models:AccessControl.Undefined}" Content="Undefined" />
                            <ComboBoxItem Tag="{x:Static models:AccessControl.FullAccess}" Content="Full access" />
                            <ComboBoxItem Tag="{x:Static models:AccessControl.ConfirmAll}" Content="Confirm all" />
                            <ComboBoxItem Tag="{x:Static models:AccessControl.ViewAndShow}" Content="View and show" />
                            <ComboBoxItem Tag="{x:Static models:AccessControl.CustomSettings}" Content="Custom settings" />
                        </ComboBox>

                        <TextBlock Margin="0,18,0,0" Text="Default TeamViewer.exe path" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="DefaultPathBox" />

                        <TextBlock Margin="0,18,0,0" Text="Default Wake-on-LAN broadcast address" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="DefaultWakeBroadcastBox" />

                        <TextBlock Margin="0,18,0,0" Text="Inherited pre-launch script" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="PreLaunchScriptBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="90"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />

                        <TextBlock Margin="0,18,0,0" Text="Inherited post-launch script" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="PostLaunchScriptBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="90"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EditorCard}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Operational note" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Folder defaults are strongest when they represent a stable customer, site, or environment pattern. Keep them predictable and let exceptions live on individual connections."
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,20,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button x:Name="SaveButton"
                    DockPanel.Dock="Right"
                    Content="Save folder"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    Click="Save_Click" />
        </DockPanel>
    </Grid>
</Window>
