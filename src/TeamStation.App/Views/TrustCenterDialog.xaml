<Window x:Class="TeamStation.App.Views.TrustCenterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TeamStation.App.ViewModels"
        Title="Trust Center"
        Width="780"
        Height="720"
        MinWidth="660"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22,18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="LabelCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Subtext1Brush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,12,4" />
        </Style>
        <Style x:Key="ValueCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE72E;"
                           Foreground="{DynamicResource Subtext1Brush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="LOCAL HEALTH" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Trust Center" Style="{StaticResource DisplayText}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource SectionSubtitleText}">
                <Run Text="Read-only health snapshot. TeamStation never phones home; everything below comes from the local registry, file system, and the bundled offline CVE registry. Generated " />
                <Run Text="{Binding Report.GeneratedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', Mode=OneWay}" />
                <Run Text="." />
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- TeamViewer client safety (CVE registry verdict) -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.Safety.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.Safety.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.Safety.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.Safety.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="TeamViewer client safety" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding Report.Safety.Headline}"
                                   Style="{StaticResource ValueCell}" />

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Report.Safety.MatchedCves}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface0Brush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,4,0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Severity}" FontSize="11" Foreground="{DynamicResource Subtext1Brush}" Margin="0,0,8,0" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource Subtext1Brush}">
                                                    <Run Text="fixed in " /><Run Text="{Binding FixedIn}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Margin="0,4,0,0"
                                                       Style="{StaticResource ValueCell}" />
                                            <TextBlock Text="{Binding RemediationUrl}"
                                                       Margin="0,2,0,0"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Subtext1Brush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Binary provenance -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.Provenance.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.Provenance.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.Provenance.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.Provenance.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="TeamViewer.exe provenance" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,12"
                                   Text="{Binding Report.Provenance.Headline}"
                                   Style="{StaticResource ValueCell}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Resolved path" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Report.Provenance.Path}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="1" Text="File version" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Report.Provenance.FileVersion}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="2" Text="Signature" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Report.Provenance.SignatureStateText}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="3" Text="Publisher" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Report.Provenance.PublisherSubject}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="4" Text="Install root" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding Report.Provenance.InstallRootText}"
                                       Style="{StaticResource ValueCell}" />
                        </Grid>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding Report.Provenance.Provenance.Advice}"
                                   Style="{StaticResource BodyMutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Local database -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.Database.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.Database.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.Database.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.Database.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="Local database" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,12"
                                   Text="{Binding Report.Database.Headline}"
                                   Style="{StaticResource ValueCell}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Path" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Report.Database.Path}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="1" Text="Size" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Report.Database.SizeText}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="2" Text="Last write" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Report.Database.LastWriteText}"
                                       Style="{StaticResource ValueCell}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Encrypted mirror -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.Mirror.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.Mirror.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.Mirror.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.Mirror.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="Encrypted mirror" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,4"
                                   Text="{Binding Report.Mirror.Headline}"
                                   Style="{StaticResource ValueCell}" />
                        <TextBlock Text="{Binding Report.Mirror.DetailText}"
                                   Style="{StaticResource BodyMutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- CVE registry -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.Registry.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.Registry.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.Registry.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.Registry.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="CVE registry" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,12"
                                   Text="{Binding Report.Registry.Headline}"
                                   Style="{StaticResource ValueCell}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Last updated" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Report.Registry.LastUpdated}"
                                       Style="{StaticResource ValueCell}" />

                            <TextBlock Grid.Row="1" Text="Source" Style="{StaticResource LabelCell}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Report.Registry.Source}"
                                       Style="{StaticResource ValueCell}" />
                        </Grid>

                        <ItemsControl Margin="0,8,0,0"
                                      ItemsSource="{Binding Report.Registry.Diagnostics}"
                                      Visibility="{Binding Report.Registry.HasDiagnostics, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource YellowBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Web API -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusPill}"
                                    Background="{Binding Report.WebApi.Tone, Converter={StaticResource ToneToSoftBrush}}"
                                    BorderBrush="{Binding Report.WebApi.Tone, Converter={StaticResource ToneToBrush}}">
                                <TextBlock Text="{Binding Report.WebApi.Tone, Converter={StaticResource ToneToLabel}}"
                                           Foreground="{Binding Report.WebApi.Tone, Converter={StaticResource ToneToBrush}}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="TeamViewer Web API" Style="{StaticResource SectionTitleText}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,4"
                                   Text="{Binding Report.WebApi.Headline}"
                                   Style="{StaticResource ValueCell}" />
                        <TextBlock Text="{Binding Report.WebApi.DetailText}"
                                   Style="{StaticResource BodyMutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Content="Close"
                    Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="Close_Click" />
            <Button DockPanel.Dock="Right"
                    Content="Refresh"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding RefreshCommand}" />
            <TextBlock VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource Subtext1Brush}"
                       Text="Local data only. Never uploaded; never phones home." />
        </DockPanel>
    </Grid>
</Window>
