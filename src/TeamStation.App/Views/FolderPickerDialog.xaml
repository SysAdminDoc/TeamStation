<Window x:Class="TeamStation.App.Views.FolderPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TeamStation.App.Views"
        Title="Move item"
        Width="460"
        Height="620"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PickerCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                           FontSize="12"
                           Text="&#xE8DE;"
                           Foreground="{StaticResource Subtext1Brush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="MOVE" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Choose destination" Style="{StaticResource HeadlineText}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Pick a target folder, or move the item to the top level if it should sit outside any folder."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource PickerCard}">
            <TreeView x:Name="Tree"
                      ItemsSource="{Binding RootFolders}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      MouseDoubleClick="Tree_MouseDoubleClick"
                      AutomationProperties.Name="Destination folders"
                      AutomationProperties.HelpText="Choose a destination folder, or use Move to top level."
                      KeyboardNavigation.TabNavigation="Once">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type local:PickerFolderItem}" ItemsSource="{Binding Children}">
                        <Border x:Name="PickerRow"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                           FontSize="13"
                                           Text="&#xE8B7;"
                                           Foreground="{Binding AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsMouseOver}" Value="True">
                                <Setter TargetName="PickerRow" Property="Background" Value="{DynamicResource Surface1Brush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsKeyboardFocusWithin}" Value="True">
                                <Setter TargetName="PickerRow" Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="PickerRow" Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                                <Setter TargetName="PickerRow" Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,20,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Content="Move to top level"
                    Style="{StaticResource GhostButton}"
                    Click="Root_Click" />
            <Button DockPanel.Dock="Right"
                    x:Name="OkButton"
                    Content="Move"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    ToolTip="Choose a destination folder first"
                    ToolTipService.ShowOnDisabled="True"
                    Click="Ok_Click" />
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </DockPanel>
    </Grid>
</Window>
