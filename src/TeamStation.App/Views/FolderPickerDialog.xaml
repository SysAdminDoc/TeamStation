<Window x:Class="TeamStation.App.Views.FolderPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TeamStation.App.Views"
        Title="Move item"
        Width="460"
        Height="620"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PickerCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MantleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Move item" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Margin="0,10,0,0"
                       Text="Choose a destination folder, or move the item to the top level if it should sit outside any folder."
                       Style="{StaticResource SectionSubtitleText}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource PickerCard}">
            <TreeView x:Name="Tree"
                      ItemsSource="{Binding RootFolders}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      MouseDoubleClick="Tree_MouseDoubleClick">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type local:PickerFolderItem}" ItemsSource="{Binding Children}">
                        <Border x:Name="PickerRow"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="14"
                                        Height="14"
                                        CornerRadius="4"
                                        Background="{Binding AccentBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        Margin="0,2,10,0" />
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsMouseOver}" Value="True">
                                <Setter TargetName="PickerRow" Property="Background" Value="{StaticResource Surface0Brush}" />
                                <Setter TargetName="PickerRow" Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="PickerRow" Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                <Setter TargetName="PickerRow" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,20,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Content="Move to top level"
                    Style="{StaticResource GhostButton}"
                    Click="Root_Click" />
            <Button DockPanel.Dock="Right"
                    x:Name="OkButton"
                    Content="Move"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="Ok_Click" />
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </DockPanel>
    </Grid>
</Window>
