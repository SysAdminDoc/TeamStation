<Window x:Class="TeamStation.App.Views.FolderPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TeamStation.App.ViewModels"
        Title="Move to folder"
        Width="420" Height="520"
        MinWidth="380" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Pick a destination folder, or 'Root' to move to the top level."
                   Foreground="{StaticResource Subtext1Brush}" TextWrapping="Wrap" />
        <Border Grid.Row="1" Margin="0,12,0,0" Background="{StaticResource MantleBrush}" CornerRadius="6">
            <TreeView x:Name="Tree"
                      ItemsSource="{Binding RootFolders}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource TextBrush}"
                      SelectedItemChanged="Tree_SelectedItemChanged">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FolderNode}" ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource MauveBrush}" FontWeight="SemiBold" />
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Root" Click="Root_Click" />
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click" />
            <Button x:Name="OkButton" Content="Move" IsDefault="True" IsEnabled="False" Click="Ok_Click"
                    Background="{StaticResource BlueBrush}" Foreground="{StaticResource Crust}" FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</Window>
