<Window x:Class="TeamStation.App.Views.BulkProxyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set proxy"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource UiFont}"
        ShowInTaskbar="False"
        AutomationProperties.Name="Bulk proxy dialog">
    <Border Margin="16"
            Background="{DynamicResource MantleBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24,22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="DialogTitleText" Style="{StaticResource HeadlineText}" />
                <TextBlock x:Name="PromptText"
                           Margin="0,8,0,0"
                           Text="Apply the same TeamViewer proxy route to every selected connection."
                           Style="{StaticResource SectionSubtitleText}" />
            </StackPanel>

            <Border x:Name="ValidationBorder"
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Style="{StaticResource ValidationBanner}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                               FontSize="13"
                               Text="&#xE814;"
                               Foreground="{StaticResource RedBrush}"
                               VerticalAlignment="Top"
                               Margin="0,1,10,0" />
                    <TextBlock x:Name="ValidationText"
                               Foreground="{StaticResource RedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Host" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="ProxyHostBox"
                                 AutomationProperties.Name="Proxy host"
                                 AutomationProperties.HelpText="Required proxy host. Use brackets for IPv6 hosts."
                                 TextChanged="RequiredField_TextChanged" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="ProxyPortBox"
                                 AutomationProperties.Name="Proxy port"
                                 AutomationProperties.HelpText="Required proxy port from 1 to 65535."
                                 TextChanged="RequiredField_TextChanged" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Username" Style="{StaticResource FieldLabelText}" />
                        <TextBox x:Name="ProxyUserBox"
                                 AutomationProperties.Name="Proxy username" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Password" Style="{StaticResource FieldLabelText}" />
                        <PasswordBox x:Name="ProxyPasswordBox"
                                     AutomationProperties.Name="Proxy password" />
                    </StackPanel>
                </Grid>

                <Border Margin="0,14,0,0"
                        Background="{DynamicResource Surface0Brush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <TextBlock Text="This replaces proxy routing on every selected connection. Leave username and password empty when the proxy does not require credentials."
                               Foreground="{DynamicResource Subtext1Brush}"
                               FontSize="12"
                               LineHeight="18"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <DockPanel Grid.Row="3" Margin="0,20,0,0" LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Margin="8,0,0,0"
                        AutomationProperties.Name="Cancel"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button DockPanel.Dock="Right"
                        x:Name="ApplyButton"
                        Content="Apply proxy"
                        Style="{StaticResource PrimaryButton}"
                        AutomationProperties.Name="Apply proxy"
                        ToolTip="Enter a proxy host and port before applying"
                        ToolTipService.ShowOnDisabled="True"
                        IsDefault="True"
                        Click="Apply_Click" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
