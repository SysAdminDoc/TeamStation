<Window x:Class="TeamStation.App.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Margin="20"
            Background="{StaticResource MantleBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="DialogTitleText" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="PromptText" Margin="0,10,0,0" Style="{StaticResource SectionSubtitleText}" />
            </StackPanel>

            <TextBox x:Name="ValueBox" Grid.Row="1" Margin="0,18,0,0" />

            <DockPanel Grid.Row="2" Margin="0,20,0,0" LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Margin="8,0,0,0"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button DockPanel.Dock="Right"
                        Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Click="Ok_Click" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
