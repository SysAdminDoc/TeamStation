<Application x:Class="TeamStation.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TeamStation.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Catppuccin Mocha palette -->
            <Color x:Key="Base">#FF1E1E2E</Color>
            <Color x:Key="Mantle">#FF181825</Color>
            <Color x:Key="Crust">#FF11111B</Color>
            <Color x:Key="Surface0">#FF313244</Color>
            <Color x:Key="Surface1">#FF45475A</Color>
            <Color x:Key="Surface2">#FF585B70</Color>
            <Color x:Key="Text">#FFCDD6F4</Color>
            <Color x:Key="Subtext0">#FFA6ADC8</Color>
            <Color x:Key="Subtext1">#FFBAC2DE</Color>
            <Color x:Key="Overlay0">#FF6C7086</Color>
            <Color x:Key="Blue">#FF89B4FA</Color>
            <Color x:Key="Mauve">#FFCBA6F7</Color>
            <Color x:Key="Green">#FFA6E3A1</Color>
            <Color x:Key="Red">#FFF38BA8</Color>
            <Color x:Key="Yellow">#FFF9E2AF</Color>

            <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource Base}" />
            <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource Mantle}" />
            <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource Crust}" />
            <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}" />
            <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}" />
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text}" />
            <SolidColorBrush x:Key="Subtext0Brush" Color="{StaticResource Subtext0}" />
            <SolidColorBrush x:Key="Subtext1Brush" Color="{StaticResource Subtext1}" />
            <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource Blue}" />
            <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource Mauve}" />
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
