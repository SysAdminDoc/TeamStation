<Window x:Class="TeamStation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TeamStation.App.ViewModels"
        mc:Ignorable="d"
        Title="TeamStation"
        Height="720" Width="1200"
        MinHeight="480" MinWidth="720"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="{StaticResource BlueBrush}" />
            <Setter Property="Foreground" Value="{StaticResource Crust}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="Button" x:Key="IconButton" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
            <Setter Property="Padding" Value="2,3" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="TextBox" x:Key="SearchBox">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="220" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="TeamStation" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource BlueBrush}" />
                    <TextBlock x:Name="VersionBadge" Margin="8,2,0,0"
                               Foreground="{StaticResource Subtext0Brush}" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource Subtext0Brush}"
                           Text="{Binding TvExePath}"
                           ToolTip="{Binding TvExePath}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource MantleBrush}" Padding="16,10"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource CrustBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Launch" Style="{StaticResource PrimaryButton}" Command="{Binding LaunchCommand}" />
                    <Button Content="Add entry" Style="{StaticResource ToolbarButton}" Command="{Binding AddEntryCommand}" />
                    <Button Content="Add folder" Style="{StaticResource ToolbarButton}" Command="{Binding AddFolderCommand}" />
                    <Button Content="Edit" Style="{StaticResource ToolbarButton}" Command="{Binding EditCommand}" />
                    <Button Content="Rename" Style="{StaticResource ToolbarButton}" Command="{Binding RenameCommand}" />
                    <Button Content="Move" Style="{StaticResource ToolbarButton}" Command="{Binding MoveCommand}" />
                    <Button Content="Delete" Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}" />
                    <Button Content="Import JSON" Style="{StaticResource ToolbarButton}" Command="{Binding ImportCommand}" />
                    <Button Content="Import CSV" Style="{StaticResource ToolbarButton}" Command="{Binding ImportCsvCommand}"
                            ToolTip="Import entries from a CSV with a header row. Common column names are auto-detected (name/alias, teamviewer_id/id, group/folder, password, notes, tags)." />
                    <Button Content="Export" Style="{StaticResource ToolbarButton}" Command="{Binding ExportCommand}" />
                    <Button Content="Log" Style="{StaticResource ToolbarButton}" Command="{Binding ToggleLogCommand}" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                    <Button Grid.Column="1" Content="Clear" Style="{StaticResource IconButton}"
                            Margin="8,0,0,0" Command="{Binding ClearSearchCommand}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="16,12,16,12" Background="{StaticResource MantleBrush}" CornerRadius="6">
            <TreeView x:Name="Tree"
                      ItemsSource="{Binding RootNodes}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource TextBrush}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      MouseDoubleClick="Tree_MouseDoubleClick"
                      Padding="8">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FolderNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                       Fill="{Binding AccentBrush}" RadiusX="2" RadiusY="2" />
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                    <DataTemplate DataType="{x:Type vm:EntryNode}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                       Fill="{StaticResource BlueBrush}" RadiusX="5" RadiusY="5" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding Summary}" Margin="16,0,8,0"
                                       Foreground="{StaticResource Subtext0Brush}" FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </TreeView.Resources>
                <TreeView.ContextMenu>
                    <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Launch" Command="{Binding LaunchCommand}" FontWeight="SemiBold" />
                        <Separator />
                        <MenuItem Header="Add entry" Command="{Binding AddEntryCommand}" />
                        <MenuItem Header="Add folder" Command="{Binding AddFolderCommand}" />
                        <MenuItem Header="Add subfolder" Command="{Binding AddSubfolderCommand}" />
                        <Separator />
                        <MenuItem Header="Edit..." Command="{Binding EditCommand}" />
                        <MenuItem Header="Rename..." Command="{Binding RenameCommand}" />
                        <MenuItem Header="Move to..." Command="{Binding MoveCommand}" />
                        <MenuItem Header="Delete" Command="{Binding DeleteCommand}" />
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource MantleBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource CrustBrush}"
                Height="180"
                Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Log" Foreground="{StaticResource Subtext1Brush}"
                           FontWeight="SemiBold" Margin="16,8,16,4" />
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Log}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         Margin="8,0,8,8">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="8,2" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TimeDisplay}"
                                           Foreground="{StaticResource Subtext0Brush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding LevelTag}" Margin="10,0,10,0"
                                           Foreground="{Binding LevelBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Width="48" />
                                <TextBlock Grid.Column="2" Text="{Binding Message}"
                                           Foreground="{StaticResource TextBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource CrustBrush}" Padding="16,6">
            <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="11"
                       Text="{Binding Status}" />
        </Border>
    </Grid>
</Window>
