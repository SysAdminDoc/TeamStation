<Window x:Class="TeamStation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TeamStation.App"
        mc:Ignorable="d"
        Title="TeamStation"
        Height="720" Width="1200"
        MinHeight="480" MinWidth="720"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="TeamStation" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource BlueBrush}" />
                    <TextBlock x:Name="VersionBadge" Margin="8,2,0,0"
                               Foreground="{StaticResource Subtext0Brush}" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource Subtext0Brush}"
                           Text="Connection manager for TeamViewer" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource MantleBrush}">
                <StackPanel Margin="16">
                    <TextBlock Text="Folders" FontWeight="SemiBold"
                               Foreground="{StaticResource Subtext1Brush}" />
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource Subtext0Brush}"
                               TextWrapping="Wrap"
                               Text="Tree view lands in v0.1.0. Spike harness first." />
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource CrustBrush}"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Welcome" FontSize="22" FontWeight="Light"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Grid.Row="1" Margin="0,8,0,0"
                           Foreground="{StaticResource Subtext0Brush}" TextWrapping="Wrap"
                           Text="TeamStation is a connection manager for TeamViewer on Windows. This build is the v0.0.2 scaffold — models, validators, CLI/URI builders, and the feasibility spike tool are in place. See ROADMAP.md for what lands next." />

                <Border Grid.Row="2" Margin="0,24,0,0" Padding="16"
                        Background="{StaticResource Surface0Brush}" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="TeamViewer detection"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MauveBrush}" />
                        <TextBlock x:Name="TvStatus" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource Subtext1Brush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource CrustBrush}" Padding="16,6">
            <TextBlock Foreground="{StaticResource Subtext0Brush}" FontSize="11"
                       Text="Scaffold build — no persistent data yet" />
        </Border>
    </Grid>
</Window>
